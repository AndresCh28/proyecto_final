<ReportesScreen>:
    ScreenShell:
        TopBar:
            title: "Reportes"
            subtitle: "Resumen ejecutivo y salidas consultivas del sistema."

        GridLayout:
            cols: 2
            spacing: "12dp"
            size_hint_y: None
            height: self.minimum_height

            MetricCard:
                title: "Financiero"
                value: "Listo"
            MetricCard:
                title: "Presupuestos"
                value: "Listo"
                accent: 0.86, 0.56, 0.18, 1

        SectionCard:
            InfoRow:
                label_text: "Reporte financiero"
                value_text: "Disponible"
            InfoRow:
                label_text: "Reporte de propuestas"
                value_text: "Disponible"
            InfoRow:
                label_text: "Actividad de comisiones"
                value_text: "Disponible"
            BoxLayout:
                size_hint_y: None
                height: "44dp"
                spacing: "10dp"

                MenuButton:
                    text: "Ver resumen"

                SecondaryButton:
                    text: "Exportacion futura"

        SecondaryButton:
            text: "Volver al dashboard"
            on_release: root.navigate("dashboard")
