#:kivy 2.0

WindowManager:
    LoginScreen:
    DashboardScreen:
    ComisionesScreen:
    PresupuestosScreen:
    ReportesScreen:
    NotificacionesScreen:

<LoginScreen>:
    name: "login"

    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "SIGECOM"
            font_size: 32

        TextInput:
            hint_text: "Correo"
            multiline: False

        TextInput:
            hint_text: "Contraseña"
            password: True
            multiline: False

        Button:
            text: "Iniciar Sesión"
            on_press:
                app.root.current = "dashboard"

<DashboardScreen>:
    name: "dashboard"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Label:
            text: "Panel Principal"
            font_size: 24

        Button:
            text: "Gestión de Comisiones"
            on_press:
                app.root.current = "comisiones"

        Button:
            text: "Presupuestos"
            on_press:
                app.root.current = "presupuestos"

        Button:
            text: "Reportes"
            on_press:
                app.root.current = "reportes"

        Button:
            text: "Notificaciones"
            on_press:
                app.root.current = "notificaciones"

        Button:
            text: "Cerrar Sesión"
            on_press:
                app.root.current = "login"

<ComisionesScreen>:
    name: "comisiones"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Label:
            text: "Gestión de Comisiones"
            font_size: 22

        Button:
            text: "Volver"
            on_press:
                app.root.current = "dashboard"

<PresupuestosScreen>:
    name: "presupuestos"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Label:
            text: "Módulo de Presupuestos"
            font_size: 22

        Button:
            text: "Volver"
            on_press:
                app.root.current = "dashboard"

<ReportesScreen>:
    name: "reportes"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Label:
            text: "Módulo de Reportes"
            font_size: 22

        Button:
            text: "Volver"
            on_press:
                app.root.current = "dashboard"

<NotificacionesScreen>:
    name: "notificaciones"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Label:
            text: "Notificaciones"
            font_size: 22

        Button:
            text: "Volver"
            on_press:
                app.root.current = "dashboard"